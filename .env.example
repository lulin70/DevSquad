# DevSquad Environment Configuration
# Copy this file to .env and fill in your values: cp .env.example .env

# === LLM Backend (Optional - Mock mode works without any key) ===

# OpenAI (GPT-4, GPT-3.5)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Default backend: mock | openai | anthropic
DEVSQUAD_LLM_BACKEND=mock

# === Optional Integrations ===

# WorkBuddy Claw path (auto-detected if not set)
WORKBUDDY_CLAW_PATH=

# === DevSquad Settings ===
DEVSQUAD_PERSIST_DIR=.devsquad_data
DEVSQUAD_LANG=auto
