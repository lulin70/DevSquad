# DevSquad Production Environment Variables Template
# ===================================================
#
# Description:
#   Template file for production environment variables.
#   Copy this file to .env.production and update values.
#
# Usage:
#   cp env.production .env.production
#   nano .env.production  # Edit with your actual values
#   chmod 600 .env.production  # Secure permissions
#
# Security:
#   - NEVER commit this file with real secrets to version control!
#   - Use strong, unique passwords (minimum 32 characters)
#   - Rotate secrets regularly
#   - Consider using a secret manager (HashiCorp Vault, AWS Secrets Manager)
#

# ===== LLM Backend Configuration =====

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# Anthropic Configuration (alternative to OpenAI)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# ANTHROPIC_MODEL=claude-3-opus-20240229

# Default LLM backend: openai | anthropic | mock
DEVSQUAD_LLM_BACKEND=openai

# ===== DevSquad API Server Configuration =====

# Server settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_LOG_LEVEL=info

# CORS settings (comma-separated origins)
CORS_ORIGINS=https://your-domain.com,https://api.your-domain.com

# ===== Authentication Configuration =====

# Enable authentication: true | false
AUTH_ENABLED=true

# Session secret key (CHANGE THIS IN PRODUCTION!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars-long

# Cookie settings
COOKIE_EXPIRY_DAYS=30
COOKIE_NAME=devsquad_auth

# Admin user credentials hash (SHA-256 of password)
# Generate with: python -c "import hashlib; print(hashlib.sha256('your-password'.encode()).hexdigest())"
ADMIN_PASSWORD_HASH=5e884898da28047151d0e56f8dc6292773603d0d6aabbdd62a11ef721d1542d8

# ===== Alert Notification System =====

# Slack integration (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TXXXXXXXX/BXXXXXXXXX/XXXXXXXXXXXXXXXXXX
SLACK_CHANNEL=#devsquad-alerts
SLACK_USERNAME=DevSquad Bot

# Email notification (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=devsquad-alerts@your-domain.com
SMTP_PASSWORD=your-app-password-here
ALERT_RECIPIENTS=oncall-team@your-domain.com,devops@your-domain.com

# Alert settings
ALERT_RATE_LIMIT_WINDOW_SECONDS=60
ALERT_MAX_ALERTS_PER_WINDOW=10

# ===== Database Configuration =====

# SQLite database path (relative to working directory)
DATABASE_PATH=data/devsquad_history.db

# Data retention days
DATA_RETENTION_DAYS=90

# Backup schedule (cron format)
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM

# ===== Monitoring & Logging =====

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log file paths
ACCESS_LOG_PATH=/var/log/devsquad/api-access.log
ERROR_LOG_PATH=/var/log/devsquad/api-error.log

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=60

# Performance monitoring
ENABLE_PERFORMANCE_MONITORING=true
CPU_WARNING_THRESHOLD=80
MEMORY_WARNING_THRESHOLD=85

# ===== SSL/TLS Configuration (for direct server mode) =====

# Enable HTTPS (recommended to use nginx reverse proxy instead)
SSL_ENABLED=false
SSL_CERT_FILE=/path/to/ssl/cert.pem
SSL_KEY_FILE=/path/to/ssl/key.pem

# ===== Rate Limiting =====

# API rate limiting (requests per minute per IP)
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST_SIZE=10

# Dashboard rate limiting
DASHBOARD_RATE_LIMIT_REQUESTS_PER_MINUTE=30
DASHBOARD_RATE_LIMIT_BURST_SIZE=5

# ===== Feature Flags =====

# Dashboard features
DASHBOARD_AUTO_REFRESH=false
DASHBOARD_AUTO_REFRESH_INTERVAL_SECONDS=30
DASHBOARD_ALLOW_PHASE_CONTROL=true

# API features
API_ENABLE_METRICS_ENDPOINT=true
API_ENABLE_HISTORY_ENDPOINT=true

# ===== Development Settings (DISABLE IN PRODUCTION) =====

# Debug mode
DEBUG=false

# Show detailed error messages to clients
SHOW_DETAILED_ERRORS=false

# Enable profiling
ENABLE_PROFILING=false

# ===== External Integrations (Optional) =====

# Error tracking (Sentry)
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Metrics export (Prometheus)
# PROMETHEUS_PORT=9090
